POSTGRES_USER=stock_tracer
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_DB=stock_tracer
DATABASE_URL=postgresql+asyncpg://stock_tracer:<your-postgres-password>@localhost:5433/stock_tracer
DATABASE_URL_SYNC=postgresql://stock_tracer:<your-postgres-password>@localhost:5433/stock_tracer
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=<your-secret-key-min-32-chars>
CORS_ORIGINS=["http://localhost:3000"]

# Email Report (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Stock Tracer
EMAIL_REPORT_ENABLED=false
